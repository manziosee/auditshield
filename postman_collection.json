    {
      "name": "🔗 Webhooks",
      "item": [
        {
          "name": "List Webhooks",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/webhooks/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "description": "List all configured webhook endpoints for your company."
          }
        },
        {
          "name": "Create Webhook",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) pm.collectionVariables.set('webhook_id', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/webhooks/",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://your-server.com/webhook\",\n  \"secret\": \"your-webhook-secret\",\n  \"events\": [\"employee.created\", \"payroll.run.completed\", \"document.expired\"],\n  \"is_active\": true\n}"
            },
            "description": "Register a new webhook endpoint. Events:\n- employee.created / employee.updated\n- payroll.run.completed\n- document.expired / document.expiring_soon\n- compliance.overdue\n\nAll deliveries include X-AuditShield-Signature HMAC-SHA256 header."
          }
        },
        {
          "name": "Update Webhook",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/webhooks/{{webhook_id}}/",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": false\n}"
            }
          }
        },
        {
          "name": "Delete Webhook",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/webhooks/{{webhook_id}}/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    }
