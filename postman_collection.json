          "name": "Audit Trail Export (JSON)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/audit-logs/export/?format=json",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "description": "Download audit trail as JSON array."
          }
        },
        {
          "name": "Multi-Company Portfolio (super_admin)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/companies/portfolio/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "description": "Returns all tenant companies with live compliance scores. Only accessible to super_admin role.\n\nResponse: { total_companies, companies[{ id, name, country, compliance_score, employee_count, ... }] }"
          }
        },
        {
          "name": "Payroll Variance Check",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/payroll/runs/{{payroll_run_id}}/variance-check/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "description": "Compares current payroll run against the previous completed run. Flags salary spikes >15%, missing employees, and new additions."
          }
        },
        {
          "name": "Toggle 2FA",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/toggle-2fa/",
