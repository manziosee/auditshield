              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enable\": true,\n  \"password\": \"YourCurrentPassword\"\n}"
            },
            "description": "Enable or disable two-factor authentication. Requires current password confirmation."
          }
        },
        {
          "name": "Document Extracted Fields (AI OCR)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/documents/{{document_id}}/extracted-fields/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "description": "Returns AI-extracted fields from document OCR: name, start_date, salary, contract_end."
          }
        }
      ]
